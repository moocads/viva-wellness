# Copy to .env.local — do not commit secrets. Next.js does NOT load this file automatically.

# Required: the long "Plain Token" from the builder doc (API Token section), NOT the tenant UUID.
MOOCADS_TENANT_TOKEN=

# Optional: defaults to https://superadmin.moocads.com/api/v1
# MOOCADS_API_BASE=https://superadmin.moocads.com/api/v1

# If the API returns 403 without Origin, set this to an allowed frontend origin
# (e.g. your deployed site or http://localhost:3000 during local dev).
# MOOCADS_REQUEST_ORIGIN=http://localhost:3000
