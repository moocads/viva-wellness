{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "product",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "product_name": {
      "type": "string"
    },
    "product_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "rendering_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "avaliable_location": {
      "type": "enumeration",
      "enum": [
        "BC",
        "ON"
      ]
    },
    "Documents": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "specs": {
      "type": "component",
      "repeatable": true,
      "component": "product.product-spec"
    },
    "series": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::series.series",
      "inversedBy": "products"
    }
  }
}
