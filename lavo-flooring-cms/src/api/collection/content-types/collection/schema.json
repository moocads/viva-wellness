{
  "kind": "collectionType",
  "collectionName": "collections",
  "info": {
    "singularName": "collection",
    "pluralName": "collections",
    "displayName": "Collection",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "collection_name": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "series": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::series.series",
      "mappedBy": "collection"
    },
    "description": {
      "type": "text"
    }
  }
}
